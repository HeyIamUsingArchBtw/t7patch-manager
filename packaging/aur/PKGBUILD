# Maintainer: HeyIamUsingArchBtw
pkgname=t7patch-manager
pkgver=0.4.0
pkgrel=1
pkgdesc="GTK4 app to install, launch, toggle and configure T7Patch v3 for BO3 on Linux"
arch=('any')
url="https://github.com/HeyIamUsingArchBtw/t7patch-manager"
license=('MIT')
depends=('python' 'python-gobject' 'gtk4' 'libadwaita')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("$pkgname-$pkgver.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Desktop entry
    install -Dm644 data/io.github.heyiamusingarchbtw.T7PatchManager.desktop \
        "$pkgdir/usr/share/applications/io.github.heyiamusingarchbtw.T7PatchManager.desktop"

    # Icon
    install -Dm644 data/io.github.heyiamusingarchbtw.T7PatchManager.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.heyiamusingarchbtw.T7PatchManager.svg"

    # License & docs
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
